rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and update their own profile information.
    // They can create their profile if they are authenticated.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      allow create: if request.auth.uid != null;
      allow delete: if false; // Disallow users from deleting their own profile document
    }

    // Users can only create, read, update, and delete their own workout plans.
    match /workoutPlans/{planId} {
      allow read, write: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    // Users can only create, read, update, and delete their own meal plans.
    match /mealPlans/{planId} {
      allow read, write: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    // Users can only create their own feedback. They cannot edit or delete it.
    // They should only be able to read their own feedback.
    match /feedback/{feedbackId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow read: if request.auth.uid == resource.data.userId;
      allow update, delete: if false; // Feedback is immutable
    }
  }
}